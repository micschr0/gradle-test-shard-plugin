{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices", ":semanticCommits"],
  "prCreation": "immediate",
  "rebaseWhen": "never",
  "labels": ["dependencies"],
  "dependencyDashboard": true,
  "platformAutomerge": true,
  "timezone": "Europe/Berlin",
  "schedule": ["after 8am and before 6pm on Monday"],
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "minimumReleaseAge": "0 days",
    "schedule": ["at any time"],
    "automerge": false
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["after 8am and before 6pm on Sunday"]
  },
  "packageRules": [
    {
      "description": "gradle-api patches stay on the 8.11 binary-compat floor; block minor/major, and never automerge a compile-floor bump",
      "matchPackageNames": ["dev.gradleplugins:gradle-api"],
      "matchUpdateTypes": ["minor", "major"],
      "enabled": false
    },
    {
      "matchPackageNames": ["dev.gradleplugins:gradle-api"],
      "automerge": false
    },
    {
      "description": "Own plugin is not on the Portal — skip lookup",
      "matchPackageNames": ["de.micschro.shardwise{/,}**"],
      "enabled": false
    },
    {
      "description": "e2e uses the min-supported Gradle image on purpose",
      "matchManagers": ["gitlabci"],
      "matchPackageNames": ["gradle"],
      "enabled": false
    },
    {
      "description": "Group Kotlin ecosystem",
      "matchPackageNames": ["/^org\\.jetbrains\\.kotlin/"],
      "groupName": "Kotlin"
    },
    {
      "description": "Group code-quality tools",
      "matchPackageNames": ["/^io\\.gitlab\\.arturbosch\\.detekt/", "/^org\\.jlleitschuh\\.gradle\\.ktlint/"],
      "groupName": "code-quality"
    },
    {
      "description": "Automerge non-major Gradle/dependency updates (CI is the gate)",
      "matchManagers": ["gradle", "gradle-wrapper"],
      "matchUpdateTypes": ["patch", "minor"],
      "minimumReleaseAge": "3 days",
      "automerge": true
    },
    {
      "description": "Group GitHub Actions bumps and automerge non-major",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "github-actions",
      "minimumReleaseAge": "3 days",
      "automerge": true
    },
    {
      "description": "Major updates require manual review",
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ]
}
