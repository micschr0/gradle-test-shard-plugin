root = true

[*]
charset = utf-8
# Disable all ktlint rules by default; enable only no-unused-imports below.
ktlint_standard = disabled
ktlint_standard_no-unused-imports = enabled
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.{yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.sh]
indent_size = 2

[*.json5]
indent_size = 2